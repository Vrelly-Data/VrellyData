# ============================================================================
# Environment files
# ============================================================================
# .env.development  — Dev Supabase project (used by `npm run dev` automatically)
# .env.production   — Prod Supabase project (used by `npm run build` automatically)
# .env.local        — Local overrides (highest priority, gitignored)
#                     Copy prod values here to develop against prod DB
#
# Vite loads env files by mode: https://vitejs.dev/guide/env-and-mode
#
# ----------------------------------------------------------------------------
# Frontend (Vite) vars — prefixed VITE_, exposed to browser
# ----------------------------------------------------------------------------
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# ============================================================================
# Supabase Edge Function secrets
# ============================================================================
# These are NOT Vite vars — they're set on the Supabase side via:
#   supabase secrets set KEY=value --project-ref <project-ref>
# or in the Supabase dashboard under Edge Functions → Secrets.
# Listed here for documentation only. Never commit real values.
#
# ----------------------------------------------------------------------------
# Supabase server-side (auto-populated by Supabase in edge functions, but
# listed here in case you run functions locally with `supabase functions serve`)
# ----------------------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----------------------------------------------------------------------------
# Stripe — required for billing flows
# ----------------------------------------------------------------------------
# Secret API key: sk_live_... for production, sk_test_... for test mode.
STRIPE_SECRET_KEY=sk_test_xxx

# Signing secret from Stripe Dashboard → Developers → Webhooks → (endpoint).
# Must match the webhook endpoint configured for this Supabase project.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs — one per tier × billing interval (6 total).
# Get these from Stripe Dashboard → Products → (tier) → pricing section.
# Must point at real prices in the account whose key is above.
STRIPE_PRICE_STARTER_MONTHLY=price_xxx
STRIPE_PRICE_STARTER_ANNUAL=price_xxx
STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_xxx
STRIPE_PRICE_PROFESSIONAL_ANNUAL=price_xxx
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_xxx
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_xxx
# Note: Agent-tier price IDs are currently hardcoded in stripe-webhook/index.ts
# and create-checkout/index.ts (Agent is sales-led and doesn't run through checkout).

# ----------------------------------------------------------------------------
# Deployment URLs — used for CORS and checkout redirects
# ----------------------------------------------------------------------------
# Origin allowed by edge functions' CORS (in addition to vrelly.com).
# Set to your deployed frontend URL (e.g. Vercel preview or production URL).
ALLOWED_ORIGIN=https://vrelly.com

# Base URL used when building checkout success/cancel redirect URLs.
# Falls back to the request's Origin header if unset.
APP_URL=https://vrelly.com
