# Environment files:
#
# .env.development  — Dev Supabase project (used by `npm run dev` automatically)
# .env.production   — Prod Supabase project (used by `npm run build` automatically)
# .env.local        — Local overrides (highest priority, gitignored)
#                     Copy prod values here to develop against prod DB
#
# Vite loads env files by mode: https://vitejs.dev/guide/env-and-mode

VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_URL=https://your-project-id.supabase.co
